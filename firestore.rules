rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────

    // True if the request comes from an authenticated user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // True if the caller's UID matches the document path segment.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // True if the caller has the admin custom claim.
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // True if the write does NOT attempt to change the "role" field.
    function roleNotChanged() {
      return !("role" in request.resource.data)
        || request.resource.data.role == resource.data.role;
    }

    // ─── User documents ────────────────────────────────────────

    match /users/{userId} {
      // Users can read their own document; admins can read any user.
      allow read: if isOwner(userId) || isAdmin();

      // Users can create their own document (onUserCreate may also do this).
      allow create: if isOwner(userId);

      // Users can update their own document except the role field.
      // Admins can update anything.
      allow update: if (isOwner(userId) && roleNotChanged()) || isAdmin();

      // Only admins can delete user documents.
      allow delete: if isAdmin();

      // ── Cards subcollection ──────────────────────────────────
      match /cards/{cardId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // ── Transactions subcollection ───────────────────────────
      match /transactions/{txId} {
        // Users can read their own transactions and create new ones.
        // Admins have full access.
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }

      // ── Notifications subcollection ──────────────────────────
      match /notifications/{notifId} {
        // Users can read their own notifications.
        allow read: if isOwner(userId) || isAdmin();

        // Users can only update the isRead field on their own notifications.
        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"]);

        // Only admins (or Cloud Functions) can create / delete notifications.
        allow create, delete: if isAdmin();
      }
    }

    // ─── Admin collection ──────────────────────────────────────

    match /admin/{document=**} {
      // Only admins can read and write anything under /admin.
      allow read, write: if isAdmin();
    }

    // ─── Deny everything else by default ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
