rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function roleNotChanged() {
      return !("role" in request.resource.data)
        || request.resource.data.role == resource.data.role;
    }

    function ownerCreateRoleIsUser() {
      return request.resource.data.role == 'user';
    }

    // ─── Validation helpers ──────────────────────────────────

    function isString(field) {
      return field is string;
    }

    function isNumber(field) {
      return field is number;
    }

    function isBool(field) {
      return field is bool;
    }

    // Validates user document fields on create/update.
    function validUserData() {
      let d = request.resource.data;
      return d.email is string
        && d.email.size() > 0
        && d.email.size() <= 320
        && d.role is string
        && d.role in ['user', 'admin']
        && d.plan is string
        && d.plan in ['free', 'premium']
        && d.mfaEnabled is bool
        && d.biometricEnabled is bool;
    }

    // Validates card document fields.
    function validCardData() {
      let d = request.resource.data;
      return d.retailer is string
        && d.retailer.size() > 0
        && d.retailer.size() <= 100
        && d.balance is number
        && d.balance >= 0
        && d.originalBalance is number
        && d.originalBalance >= 0
        && d.status is string
        && d.status in ['active', 'depleted', 'expired', 'archived'];
    }

    // Restricts which fields an admin can update on user documents.
    function adminUpdateAllowed() {
      let allowed = ['isSuspended', 'suspensionReason', 'plan', 'role', 'updatedAt'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // Restricts card owner updates to safe fields.
    // Balance updates are allowed from the client balance checker.
    function ownerCardUpdateAllowed() {
      let allowed = ['notes', 'status', 'balance', 'lastBalanceCheck', 'updatedAt'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // Validates transaction document fields.
    function validTransactionData() {
      let d = request.resource.data;
      return d.cardId is string
        && d.retailer is string
        && d.type is string
        && d.type in ['purchase', 'refund', 'balance_check', 'adjustment', 'transfer']
        && d.amount is number
        && d.balanceAfter is number
        && d.balanceAfter >= 0;
    }

    // ─── User documents ────────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if (isOwner(userId) && ownerCreateRoleIsUser() && validUserData())
        || (isAdmin() && validUserData());

      allow update: if (isOwner(userId) && roleNotChanged() && validUserData())
        || (isAdmin() && validUserData() && adminUpdateAllowed());

      allow delete: if isAdmin();

      // ── Cards subcollection ──────────────────────────────────
      match /cards/{cardId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) && validCardData()) || isAdmin();
        allow update: if (isOwner(userId) && validCardData() && ownerCardUpdateAllowed())
          || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }

      // ── Transactions subcollection ───────────────────────────
      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId) && validTransactionData()) || isAdmin();
        allow update, delete: if isAdmin();
      }

      // ── Notifications subcollection ──────────────────────────
      match /notifications/{notifId} {
        allow read: if isOwner(userId) || isAdmin();

        allow update: if isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"]);

        allow create, delete: if isAdmin();
      }
    }

    // ─── Retailer configs (balance checker) ─────────────────────
    // Read-only for authenticated clients; managed by admin/Cloud Functions.
    match /retailer_configs/{retailerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Balance check analytics ──────────────────────────────
    // Authenticated users can write events; only admin can read.
    match /analytics/balance_checks/events/{eventId} {
      allow create: if isAuthenticated()
        && request.resource.data.retailerId is string
        && request.resource.data.success is bool;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ─── Admin collection ──────────────────────────────────────

    // Protect admin/config from client-side writes (only backend functions should modify)
    match /admin/config {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── Deny everything else by default ───────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
